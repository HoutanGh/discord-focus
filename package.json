{
  "name": "discord-focus",
  "version": "0.1.0",
  "private": true,
  "description": "Firefox-first local WebExtension that hides persistent Discord chrome for a focused text conversation view.",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "test": "node --test tests/*.test.js",
    "lint": "eslint . && npm run check:privacy",
    "check:privacy": "node scripts/check-privacy.mjs",
    "lint:firefox": "npm run build && web-ext lint --source-dir dist/firefox",
    "watch:firefox": "node scripts/watch-firefox.mjs",
    "export:windows": "node scripts/export-windows.mjs",
    "package:firefox": "node scripts/package-firefox.mjs"
  },
  "keywords": [
    "webextension",
    "firefox",
    "discord"
  ],
  "license": "UNLICENSED",
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.5.0",
    "globals": "17.7.0",
    "jsdom": "24.1.3",
    "web-ext": "10.4.0"
  }
}
